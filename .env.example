# Transcription (via OpenRouter audio API)
TRANSCRIPTION_MODEL=google/gemini-3.1-flash-lite-preview
# Local Whisper model (unused, kept for reference)
WHISPER_MODEL=KBLab/kb-whisper-medium

# LLM / OpenRouter
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4

# Model for podcast/radio-style audio summary scripts.
# Leave empty (or unset) to fall back to LLM_MODEL.
PODCAST_MODEL=

# TTS — used for podcast/radio-style audio summaries.
# Discover speech-output models via the OpenRouter Models page or
# the Models API with `output_modalities=speech`.
TTS_MODEL=openai/gpt-4o-mini-tts
TTS_VOICE=alloy
TTS_FORMAT=mp3      # mp3 or pcm
TTS_SPEED=1.0       # supported by some providers only

# Default host style for audio summaries — can be overridden per request.
# default  = warm, personal "Dagboksradion" host (Sommar i P1-style)
# factual  = neutral, fact-only reading with no personal touch
# roasting = sarcastic, joking, on-the-edge roast
AUDIO_SUMMARY_STYLE=default

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=  # comma-separated Telegram user IDs (leave empty to allow all)

# Google Health API (Fitbit) daily sync — `python -m app.jobs.health_sync`.
# Get a refresh token once via the OAuth 2.0 Playground (https://developers.google.com/oauthplayground)
# against your own Google account, using the googlehealth.*.readonly scopes.
# NOTE: while the OAuth app is in "Testing" mode the refresh token expires after
# ~7 days — the sync will Telegram-alert you (invalid_grant) when it's time to redo this.
GOOGLE_HEALTH_CLIENT_ID=
GOOGLE_HEALTH_CLIENT_SECRET=
GOOGLE_HEALTH_REFRESH_TOKEN=
GOOGLE_HEALTH_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_HEALTH_API_BASE=https://health.googleapis.com
GOOGLE_HEALTH_SOURCE=fitbit
# Chat id for daily sync notifications. Empty => first id in TELEGRAM_ALLOWED_USERS.
HEALTH_SYNC_NOTIFY_CHAT_ID=

# Storage
DATABASE_PATH=./diary.db
AUDIO_DIR=./audio
REPORTS_DIR=./reports
AUDIO_SUMMARIES_DIR=./audio/summaries

# Server
HOST=0.0.0.0
PORT=8000
